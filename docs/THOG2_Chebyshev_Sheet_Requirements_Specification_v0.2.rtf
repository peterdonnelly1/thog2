\pard\sa180\sb260\f0\fs32\b 5. Geometry presets\b0\par
\pard\sa120\f0\fs22 Presets are flat user-facing names. They resolve to one MLP component, one QKV component, and one attention-output component. Existing presets remain available; new sheet presets are formed by composing the base options above.\par
\pard\sa100\f0\fs24\b Existing and generic presets\b0\par
\pard\f1\fs16\sa160
#  Preset              MLP component       QKV component          Attn-out component      Purpose\line
-- ------------------- ------------------- ---------------------- ----------------------- -----------------------------------------------\line
1  dense               dense               dense                  dense                   Conventional dense baseline.\line
2  depth               depth               depth                  depth                   Depth-only compact geometry; preferred curve name.\line
3  curve               depth               depth                  depth                   Compatibility alias for depth.\line
4  generic_sheet_col   generic_sheet_col   generic_sheet_col      generic_sheet_col       Preferred name for original sheet-column behaviour.\line
5  legacy_sheet_col    generic_sheet_col   generic_sheet_col      generic_sheet_col       Compatibility alias for generic_sheet_col.\line
6  generic_sheet_row   generic_sheet_row   generic_sheet_row      generic_sheet_row       Whole-model transposed generic sheet ablation.\line
7  mlp_block           mlp_block           depth                  depth                   Existing MLP block preset; attention depth-only.\line
8  head_aware_block    depth               head_aware_block       head_aware_block        Existing attention block preset; MLP depth-only.\line
9  full_block          mlp_block           head_aware_block       head_aware_block        Existing full block preset.\par
\pard\sa100\f0\fs24\b Semantic sheet presets\b0\par
\pard\f1\fs16\sa160
#  Preset                  MLP component       QKV component          Attn-out component      Purpose\line
-- ----------------------- ------------------- ---------------------- ----------------------- -----------------------------------------------\line
10 sheet_mlp               sheet_mlp           generic_sheet_col      generic_sheet_col       Semantic MLP only; attention generic.\line
11 sheet_qkv               generic_sheet_col   sheet_qkv              generic_sheet_col       Semantic QKV only.\line
12 sheet_out_dmodel        generic_sheet_col   generic_sheet_col      sheet_out_dmodel        Attention-output d_model option only.\line
13 sheet_out_local         generic_sheet_col   generic_sheet_col      sheet_out_local         Attention-output local-channel option only.\line
14 sheet_attn_dmodel       generic_sheet_col   sheet_qkv              sheet_out_dmodel        Semantic attention using d_model-output out sheet.\line
15 sheet_attn_local        generic_sheet_col   sheet_qkv              sheet_out_local         Semantic attention using local-channel out sheet.\line
16 sheet_mlp_qkv           sheet_mlp           sheet_qkv              generic_sheet_col       MLP plus semantic QKV; attention output generic.\line
17 sheet_mlp_out_dmodel    sheet_mlp           generic_sheet_col      sheet_out_dmodel        MLP plus output d_model option; QKV generic.\line
18 sheet_mlp_out_local     sheet_mlp           generic_sheet_col      sheet_out_local         MLP plus output local option; QKV generic.\line
19 sheet_full_dmodel       sheet_mlp           sheet_qkv              sheet_out_dmodel        Full semantic sheet, d_model-output version.\line
20 sheet_full_local        sheet_mlp           sheet_qkv              sheet_out_local         Full semantic sheet, local-channel version.\par

